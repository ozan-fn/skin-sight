{
    "version": 2,
    "builds": [
        {
            "src": "src/server/main.ts",
            "use": "@vercel/node"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": { "distDir": "dist", "includeFiles": ["src/server/generated"] }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "src/server/main.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
